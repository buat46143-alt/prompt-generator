{
  "buildCommand": "npm run install:frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "build": {
    "env": {
      "VITE_API_URL": "/api"
    }
  },
  "routes": [
    {"src": "/api/(?<path>.*)", "dest": "/api/index.js?path=$path"},
    {"src": "/(.*)", "dest": "/index.html"}
  ]
}